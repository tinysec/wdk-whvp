@PACKAGE_INIT@

if(DEFINED WDK7_ARCH AND NOT WDK7_ARCH STREQUAL "amd64")
    message(FATAL_ERROR "wdk-whvp only provides amd64 import libraries.")
endif()

set(WHVP_INCLUDE_DIR "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@")
set(WHVP_AMD64_LIBRARY_DIR "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@/amd64")

function(_whvp_add_imported_library target_name library_name)
    set(_whvp_library_path "${WHVP_AMD64_LIBRARY_DIR}/${library_name}.lib")
    if(NOT EXISTS "${_whvp_library_path}")
        message(FATAL_ERROR "Missing import library: ${_whvp_library_path}")
    endif()

    if(NOT TARGET "${target_name}")
        add_library("${target_name}" UNKNOWN IMPORTED)
        set_target_properties("${target_name}" PROPERTIES
            IMPORTED_LOCATION "${_whvp_library_path}"
            INTERFACE_INCLUDE_DIRECTORIES "${WHVP_INCLUDE_DIR}")
    endif()
endfunction()

_whvp_add_imported_library(whvp::WinHvPlatform WinHvPlatform)
_whvp_add_imported_library(whvp::WinHvEmulation WinHvEmulation)

if(NOT TARGET whvp::whvp)
    add_library(whvp::whvp INTERFACE IMPORTED)
    set_target_properties(whvp::whvp PROPERTIES
        INTERFACE_LINK_LIBRARIES whvp::WinHvPlatform)
endif()

check_required_components("@PROJECT_NAME@")
